NEXT_PUBLIC_ORACLE_CONTRACT_ADDRESS=""
NEXT_PUBLIC_CHAIN_ID="8453"
NEXT_PUBLIC_CHAIN="base"

# ── 앱 브랜딩 (보류) ────────────────────────────────────────────────────────
